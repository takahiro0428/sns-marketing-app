{
  "hosting": {
    "site": "sns-marketing-web",
    "public": ".output/public",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      {
        "source": "/api/**",
        "function": "server"
      },
      {
        "source": "**",
        "function": "server"
      }
    ],
    "headers": [
      {
        "source": "**/*.@(js|css|svg|png|jpg|webp|woff2)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      }
    ]
  },
  "functions": [
    {
      "source": ".output/server",
      "codebase": "default",
      "runtime": "nodejs22"
    }
  ],
  "firestore": [
    {
      "database": "sns-marketing-web",
      "rules": "firestore.rules",
      "indexes": "firestore.indexes.json"
    }
  ],
  "storage": [
    {
      "bucket": "sns-marketing-web",
      "rules": "storage.rules"
    }
  ]
}
