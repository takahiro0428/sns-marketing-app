# Firebase Client (Public)
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
# Custom Storage bucket (production: "sns-marketing-web")
FIREBASE_STORAGE_BUCKET=sns-marketing-web
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# Firestore Database
# Named database ID (production: "sns-marketing-web")
FIRESTORE_DATABASE_ID=sns-marketing-web

# Firebase Admin (Server Only)
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# Vertex AI
VERTEX_AI_PROJECT_ID=
VERTEX_AI_LOCATION=asia-northeast1
# Model name - e.g. gemini-2.5-flash, gemini-1.5-pro, gemini-2.0-flash-lite
VERTEX_AI_MODEL=gemini-2.5-flash

# Scheduler
SCHEDULER_API_KEY=

# Note API
NOTE_API_ENDPOINT=https://note.com/api

# X (Twitter) API - Can also be set per-project in the app
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
